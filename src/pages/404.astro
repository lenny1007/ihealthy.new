---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Layout title={`404 找不到網頁 | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-9xl font-black text-slate-200">404</h1>
    <h2 class="mt-8 text-2xl font-bold text-slate-800">Oops! 找不到這個頁面</h2>
    <p class="mt-4 text-slate-600 max-w-md mx-auto">
      您所尋找的頁面可能已被移除、名稱已更改，或者暫時無法使用。
    </p>
    <a href="/" class="mt-8 inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
      回首頁
    </a>
  </div>
</Layout>
