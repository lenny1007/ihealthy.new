---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="prose prose-slate prose-lg max-w-none prose-a:text-blue-600 hover:prose-a:text-blue-500 prose-img:rounded-xl">
    <div class="mb-10 text-center">
      {
        post.data.heroImage && (
          <img width={1020} height={510} src={post.data.heroImage} alt={post.data.title} class="w-full rounded-2xl shadow-lg mb-8 aspect-video object-cover" />
        )
      }
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">{post.data.title}</h1>
      <p class="text-lg text-slate-500 font-medium">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-TW', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
        {
          post.data.updatedDate && (
           <span class="italic ml-2">(最後更新: {
              post.data.updatedDate.toLocaleDateString('zh-TW', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })
            })</span>
          )
        }
      </p>
    </div>
    <div class="mt-8 pt-8 border-t border-slate-200">
      <Content />
    </div>
  </article>
</Layout>
