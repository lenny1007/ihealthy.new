---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');

// Extract tags and calculate frequencies
const tagCounts = allPosts.reduce((acc, post) => {
  const postTags = post.data.tags || [];
  postTags.forEach(tag => {
    if (tag) {
      acc[tag] = (acc[tag] || 0) + 1;
    }
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagCounts).sort((a, b) => {
  // Sort by count descending
  if (b[1] !== a[1]) return b[1] - a[1];
  // Sort alphabetically as fallback
  return a[0].localeCompare(b[0], 'zh-TW');
});
---

<Layout title="所有標籤 | iHealthy 生機實驗室" description="探索所有的健康知識標籤分類，建立專屬的醫學知識庫。">
  <div class="max-w-5xl mx-auto py-16 px-6 text-center">
    <div class="inline-block mb-3 bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800/50 px-4 py-1.5 rounded-full">
      <span class="text-blue-600 dark:text-blue-400 font-bold text-sm tracking-wider uppercase">Tags Directory</span>
    </div>
    
    <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-slate-100 mb-6">
      探索健康主題標籤
    </h1>
    <p class="text-lg text-slate-500 dark:text-slate-400 mb-16 max-w-2xl mx-auto leading-relaxed">
      這裡收錄了所有我們討論過的實證關鍵字。點擊您感興趣的健康主題，深入閱讀科學、權威的見解。
    </p>

    <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
      {sortedTags.map(([tag, count]) => {
        const safeSlug = tag.replace(/[:\/\\?*|"<>\s]/g, '-').toLowerCase();
        return (
        <a 
          href={`/tags/${safeSlug}/`}
          class="group inline-flex items-center px-4 py-2.5 md:px-5 md:py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl text-slate-700 dark:text-slate-300 font-medium hover:border-blue-400 dark:hover:border-blue-500 hover:ring-2 hover:ring-blue-100 dark:hover:ring-blue-900/50 hover:text-blue-700 dark:hover:text-blue-400 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <span class="mr-1.5 text-slate-300 dark:text-slate-600 group-hover:text-blue-400 dark:group-hover:text-blue-500 text-lg">#</span>
          <span class="text-base">{tag}</span>
          <span class="ml-3 bg-slate-100 dark:bg-slate-900 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/50 group-hover:text-blue-600 dark:group-hover:text-blue-300 text-slate-500 dark:text-slate-400 py-0.5 px-2.5 rounded-full text-xs font-bold transition-colors">
            {count}
          </span>
        </a>
      )})}
    </div>
    
    {sortedTags.length === 0 && (
      <div class="text-center py-20 bg-slate-50 rounded-3xl border border-dashed border-slate-300">
        <p class="text-slate-500">尚未建立任何標籤。</p>
      </div>
    )}
  </div>
</Layout>
