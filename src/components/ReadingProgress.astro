---
const { targetSelector = 'article' } = Astro.props;
---

<div id="reading-progress-container" class="fixed top-0 left-0 w-full h-[3px] bg-slate-200 z-50 overflow-hidden transform origin-left transition-transform duration-150 ease-out origin-top-left scale-x-0">
  <div class="h-full bg-gradient-to-r from-blue-500 to-indigo-500 w-full"></div>
</div>

<script define:vars={{ targetSelector }}>
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.getElementById('reading-progress-container');
    const targetElement = document.querySelector(targetSelector);
    
    if (!progressBar || !targetElement) return;

    const updateProgress = () => {
      // Calculate how far down the target element the user has scrolled
      const targetRect = targetElement.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      // Top of element relative to document
      const elementTop = targetRect.top + window.scrollY;
      // Total scrollable height of the element (element height - viewport height)
      // If element is smaller than viewport, progress is 100%
      const scrollableHeight = Math.max(0, targetRect.height - viewportHeight);
      
      // Current scroll position relative to the element's top
      const scrollPosition = Math.max(0, window.scrollY - elementTop);
      
      let progress = 0;
      if (scrollableHeight > 0) {
        progress = Math.min(1, Math.max(0, scrollPosition / scrollableHeight));
      } else if (window.scrollY >= elementTop) {
        progress = 1;
      }

      // Apply scaleX to progress bar
      progressBar.style.transform = `scaleX(${progress})`;
    };

    // Use requestAnimationFrame for smooth performance
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateProgress();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial call
    updateProgress();
    
    // Update on resize
    window.addEventListener('resize', updateProgress, { passive: true });
  });
</script>
