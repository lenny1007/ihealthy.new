---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.slug !== 'index')
  .map(p => ({
    title: p.data.title,
    description: p.data.description,
    slug: p.slug,
    category: p.data.category || '',
  }));
---

<div id="search-overlay" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="搜尋文章">
  {/* Backdrop */}
  <div id="search-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>

  {/* Search Panel */}
  <div class="relative max-w-2xl mx-auto mt-[10vh] px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden">
      {/* Input */}
      <div class="flex items-center border-b border-slate-200 px-4">
        <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜尋文章標題或內容..."
          autocomplete="off"
          class="w-full px-3 py-4 text-lg text-slate-900 placeholder-slate-400 outline-none bg-transparent"
        />
        <kbd class="hidden sm:inline-flex items-center px-2 py-1 text-xs font-medium text-slate-400 bg-slate-100 rounded border border-slate-200">ESC</kbd>
      </div>

      {/* Results */}
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <div id="search-empty" class="px-4 py-12 text-center text-slate-400">
          <p class="text-sm">輸入關鍵字搜尋文章</p>
        </div>
        <div id="search-list" class="hidden"></div>
        <div id="search-no-results" class="hidden px-4 py-12 text-center text-slate-400">
          <p class="text-lg mb-1">😕 找不到相關文章</p>
          <p class="text-sm">試試其他關鍵字吧</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ posts }}>
  const overlay = document.getElementById('search-overlay');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input');
  const listEl = document.getElementById('search-list');
  const emptyEl = document.getElementById('search-empty');
  const noResultsEl = document.getElementById('search-no-results');

  function openSearch() {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 50);
  }

  function closeSearch() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    listEl.classList.add('hidden');
    emptyEl.classList.remove('hidden');
    noResultsEl.classList.add('hidden');
  }

  // Global open/close
  window.openSearch = openSearch;
  backdrop.addEventListener('click', closeSearch);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay.classList.contains('hidden') ? openSearch() : closeSearch();
    }
  });

  // Search logic
  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      noResultsEl.classList.add('hidden');
      return;
    }

    const results = posts.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.description.toLowerCase().includes(q) ||
      p.category.toLowerCase().includes(q)
    );

    emptyEl.classList.add('hidden');

    if (results.length === 0) {
      listEl.classList.add('hidden');
      noResultsEl.classList.remove('hidden');
      return;
    }

    noResultsEl.classList.add('hidden');
    listEl.classList.remove('hidden');
    listEl.innerHTML = results.slice(0, 20).map(p => `
      <a href="/${p.slug}/" class="flex flex-col px-4 py-3 rounded-xl hover:bg-blue-50 transition-colors group">
        <span class="text-sm font-semibold text-slate-900 group-hover:text-blue-600 line-clamp-1">${highlight(p.title, q)}</span>
        <span class="text-xs text-slate-500 line-clamp-1 mt-0.5">${highlight(p.description, q)}</span>
      </a>
    `).join('');
  });

  function highlight(text, q) {
    if (!q) return escapeHtml(text);
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return escapeHtml(text).replace(re, '<mark class="bg-yellow-200 text-yellow-900 rounded px-0.5">$1</mark>');
  }

  function escapeHtml(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>
