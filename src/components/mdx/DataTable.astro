---
interface Props {
  theme?: 'blue' | 'purple' | 'red' | 'gray';
  caption?: string;
}

const { theme = 'blue', caption } = Astro.props;

const themeClasses = {
  blue: {
    wrapper: 'ring-sky-100',
    header: 'bg-sky-500 text-white border-sky-600',
    rowEven: 'bg-sky-50/30',
    rowOdd: 'bg-white',
    rowHover: 'hover:bg-sky-50',
    border: 'border-sky-100',
  },
  purple: {
    wrapper: 'ring-purple-100',
    header: 'bg-purple-600 text-white border-purple-700',
    rowEven: 'bg-purple-50/30',
    rowOdd: 'bg-white',
    rowHover: 'hover:bg-purple-50',
    border: 'border-purple-100',
  },
  red: {
    wrapper: 'ring-rose-100',
    header: 'bg-rose-500 text-white border-rose-600',
    rowEven: 'bg-rose-50/30',
    rowOdd: 'bg-white',
    rowHover: 'hover:bg-rose-50',
    border: 'border-rose-100',
  },
  gray: {
    wrapper: 'ring-slate-100',
    header: 'bg-slate-700 text-white border-slate-800',
    rowEven: 'bg-slate-50',
    rowOdd: 'bg-white',
    rowHover: 'hover:bg-slate-100',
    border: 'border-slate-200',
  },
};

const currentTheme = themeClasses[theme];
---

<div class="my-10 w-full overflow-hidden not-prose">
  {caption && (
    <div class="text-sm font-medium text-slate-500 mb-3 ml-1 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {caption}
    </div>
  )}
  <div class={`overflow-x-auto rounded-2xl ring-1 ${currentTheme.wrapper} shadow-lg shadow-slate-200/50`}>
    <table class="w-full text-left border-collapse min-w-[600px]">
      <thead class={`[&_th]:font-bold [&_th]:tracking-wide [&_th]:py-4 [&_th]:px-6 ${currentTheme.header}`}>
        <slot name="header" />
      </thead>
      <tbody class={`
        [&_td]:py-4 [&_td]:px-6 [&_td]:text-slate-700 [&_td]:border-b [&_td]:${currentTheme.border}
        [&_tr:last-child_td]:border-b-0
        [&_tr:nth-child(even)]:${currentTheme.rowEven}
        [&_tr:nth-child(odd)]:${currentTheme.rowOdd}
        [&_tr]:${currentTheme.rowHover}
        [&_tr]:transition-colors
        [&_strong]:text-slate-900 [&_strong]:font-bold
        [&_a]:text-blue-600 [&_a]:underline [&_a]:decoration-blue-200
        [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:my-1 [&_li]:my-0.5
      `}>
        <slot />
      </tbody>
    </table>
  </div>
</div>
