---
// src/components/mdx/Takeaway.astro
export interface Props {
  title?: string;
  icon?: string;
}

const { title = "總結 (Takeaway)", icon = "💡" } = Astro.props;
---
<div class="bg-gradient-to-b from-slate-900 to-slate-950 rounded-3xl p-6 md:p-8 my-12 shadow-2xl not-prose text-slate-300 border border-slate-800 relative overflow-hidden">
  <div class="absolute top-0 right-0 -mt-10 -mr-10 opacity-5 pointer-events-none">
    <svg width="250" height="250" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
    </svg>
  </div>

  <h3 class="text-xl md:text-2xl font-black text-white mb-8 flex items-center gap-3 relative z-10">
    <span class="text-2xl drop-shadow-md">{icon}</span>
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-400 tracking-wide">{title}</span>
  </h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 relative z-10 w-full">
    <slot />
  </div>
</div>
