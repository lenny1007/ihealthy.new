---
// src/components/mdx/TakeawayItem.astro
export interface Props {
  title: string;
  type?: 'danger' | 'warning' | 'success' | 'info';
}

const { title, type = 'info' } = Astro.props;

const titleColors = {
  danger: 'text-rose-400',
  warning: 'text-amber-400',
  success: 'text-emerald-400',
  info: 'text-cyan-400'
};
---
<div class="bg-slate-800/60 rounded-2xl p-5 border border-slate-700/50 hover:bg-slate-800 transition-colors duration-300 h-full flex flex-col">
  <h4 class={`text-[1.05rem] font-bold mb-3 ${titleColors[type]} tracking-wide`}>{title}</h4>
  <div class="text-[0.95rem] text-slate-400 leading-relaxed flex-grow">
    <slot />
  </div>
</div>
