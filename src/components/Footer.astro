---
const today = new Date();
---

<footer class="mt-20 py-10 text-center text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800">
  <p class="text-sm font-medium text-slate-600 dark:text-slate-300">
    iHealthy 生機實驗室
  </p>
  <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">
    實證健康，生活應用
  </p>
  <p class="text-xs text-slate-400 dark:text-slate-500 mt-3">
    &copy; {today.getFullYear()} All rights reserved.
  </p>
  <div class="mt-4 space-x-4 text-sm flex justify-center items-center">
    <span class="text-xs tracking-wider text-slate-400 dark:text-slate-600 uppercase font-semibold">POWERED BY ASTRO</span>
  </div>
</footer>
