---
export interface Props {
  title: string;
  description: string;
  price: string;
  imageUrl: string;
  link: string;
}

const { title, description, price, imageUrl, link } = Astro.props;
---

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-[inset_0_2px_4px_rgba(0,0,0,0.02)] hover:shadow-lg transition-all duration-300 my-8 flex flex-col md:flex-row max-w-2xl mx-auto">
  <div class="md:w-1/3 bg-slate-50 flex items-center justify-center p-4 border-b md:border-b-0 md:border-r border-slate-100">
    <img src={imageUrl} alt={title} class="max-w-full h-auto object-contain max-h-48 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
  </div>
  <div class="p-6 md:w-2/3 flex flex-col justify-between space-y-4">
    <div>
      <h3 class="text-xl font-bold text-slate-800 mb-1 leading-tight">{title}</h3>
      <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
    </div>
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100">
      <span class="text-xl font-bold tracking-tight text-blue-600">{price}</span>
      <a 
        href={link} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-slate-900 rounded-lg hover:bg-slate-800 focus:ring-4 focus:ring-slate-300 transition-all shadow-sm hover:shadow active:scale-95"
      >
        查看詳情
        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    </div>
  </div>
</div>
