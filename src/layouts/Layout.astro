---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const {
  title,
  description,
  lcpImage,
  type,
  publishedDate,
  updatedDate,
} = Astro.props;
---

<!doctype html>
<html lang="zh-TW" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={lcpImage}
      type={type}
      publishedDate={publishedDate}
      updatedDate={updatedDate}
    />
    <!-- 關鍵 CSS 內聯，避免 FCP 等待完整樣式 -->
    <style is:inline>
      body{background:#f8fafc;color:#1e293b;margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI","Microsoft JhengHei",sans-serif}
      main{min-height:100vh;padding-top:6rem;padding-bottom:3rem;padding-left:1.5rem;padding-right:1.5rem;max-width:1280px;margin-left:auto;margin-right:auto}
    </style>
    {lcpImage && <link rel="preload" href={lcpImage} as="image" />}
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased selection:bg-blue-200">
    <Header />
    <main class="min-h-screen pt-24 pb-12 px-6 sm:px-8 max-w-[1280px] mx-auto">
      <slot />
    </main>
    <Footer />
    <SpeedInsights />
    <script>
      import { inject } from '@vercel/analytics';
      if (document.readyState === 'complete') inject(); else window.addEventListener('load', function () { inject(); });
    </script>
  </body>
</html>
